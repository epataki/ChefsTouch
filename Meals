<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
--bg:#ffffff;--bg2:#f5f5f4;--t1:#1a1a1a;--t2:#6b6b6b;--t3:#a3a3a3;
--bd:rgba(0,0,0,0.08);--bd2:rgba(0,0,0,0.15);
--acc:#1D9E75;--acc-light:#E1F5EE;--acc-dark:#0F6E56;
--r-lg:12px;--r-md:8px;
--font:'DM Sans',system-ui,-apple-system,sans-serif;
--evan:#378ADD;--evan-light:#E6F1FB;--kara:#D4537E;--kara-light:#FBEAF0
}
@media(prefers-color-scheme:dark){
:root{--bg:#1a1a1a;--bg2:#262626;--t1:#e5e5e5;--t2:#a3a3a3;--t3:#737373;
--bd:rgba(255,255,255,0.08);--bd2:rgba(255,255,255,0.15);
--acc-light:#0a3d2e;--acc-dark:#5DCAA5;
--evan-light:#0c2d4a;--kara-light:#3d1528}
}
body,html{font-family:var(--font);color:var(--t1);background:var(--bg);-webkit-tap-highlight-color:transparent;overflow-x:hidden}
input,button,select,textarea{font-family:var(--font);-webkit-appearance:none}
.app{max-width:480px;margin:0 auto;padding:0 16px 80px;min-height:100dvh;position:relative}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;display:flex;background:var(--bg);border-top:0.5px solid var(--bd);z-index:50;padding:6px 0 env(safe-area-inset-bottom,8px);max-width:100%}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 4px;cursor:pointer;border:none;background:none;color:var(--t3);font-size:10px;font-family:var(--font);transition:color 0.15s}
.nav-item.active{color:var(--acc)}
.nav-item svg{width:22px;height:22px}
.header{display:flex;align-items:center;justify-content:space-between;padding:16px 0 12px;border-bottom:0.5px solid var(--bd);margin-bottom:16px}
.logo{font-family:'Instrument Serif',serif;font-size:24px;letter-spacing:-0.5px}
.logo span{color:var(--acc)}
.header-right{font-size:13px;color:var(--t3);display:flex;align-items:center;gap:8px}
.search-bar{position:relative;margin-bottom:12px}
.search-bar input{width:100%;height:40px;border-radius:20px;border:0.5px solid var(--bd);padding:0 16px 0 38px;font-size:14px;background:var(--bg2);color:var(--t1);outline:none;transition:all 0.2s}
.search-bar input:focus{border-color:var(--acc);background:var(--bg);box-shadow:0 0 0 3px rgba(29,158,117,0.12)}
.search-bar svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--t3)}
.tags{display:flex;gap:6px;overflow-x:auto;padding-bottom:8px;margin-bottom:12px;scrollbar-width:none;-webkit-overflow-scrolling:touch}
.tags::-webkit-scrollbar{display:none}
.tag{padding:6px 14px;border-radius:20px;font-size:12px;border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;white-space:nowrap;transition:all 0.15s;color:var(--t2)}
.tag:hover{border-color:var(--bd2)}
.tag.active{background:var(--acc);color:white;border-color:var(--acc);font-weight:500}
.tag.fav-evan{background:var(--evan-light);color:var(--evan);border-color:var(--evan)}
.tag.fav-kara{background:var(--kara-light);color:var(--kara);border-color:var(--kara)}
.recipe-list{display:flex;flex-direction:column;gap:8px}
.recipe-card{display:flex;gap:12px;padding:12px;border-radius:var(--r-lg);border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;transition:all 0.15s;align-items:center}
.recipe-card:active{transform:scale(0.98)}
.recipe-thumb{width:46px;height:46px;border-radius:var(--r-md);background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
.recipe-info{flex:1;min-width:0}
.recipe-title-row{display:flex;align-items:center;gap:6px}
.recipe-title{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fav-dots{display:flex;gap:3px;flex-shrink:0}
.fav-dot{width:8px;height:8px;border-radius:50%}
.fav-dot.evan{background:var(--evan)}
.fav-dot.kara{background:var(--kara)}
.recipe-meta{font-size:11px;color:var(--t3);display:flex;gap:8px;align-items:center;margin-top:2px}
.recipe-meta span{display:flex;align-items:center;gap:3px}
.recipe-tag-pill{font-size:10px;padding:2px 7px;border-radius:10px;background:var(--acc-light);color:var(--acc-dark);font-weight:500}
.empty-state{text-align:center;padding:40px 16px;color:var(--t3)}
.empty-state p{font-size:13px;line-height:1.6}
.fab{position:fixed;bottom:76px;right:20px;width:52px;height:52px;border-radius:50%;background:var(--acc);color:white;border:none;font-size:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(29,158,117,0.3);transition:all 0.15s;z-index:40}
.fab:active{transform:scale(0.93)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:200;display:flex;align-items:flex-end;justify-content:center}
.modal{background:var(--bg);border-radius:16px 16px 0 0;width:100%;max-width:480px;max-height:90vh;overflow-y:auto;padding:20px;animation:slideUp 0.25s ease;-webkit-overflow-scrolling:touch}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.modal-header h2{font-size:17px;font-weight:500}
.close-btn{background:none;border:none;font-size:18px;cursor:pointer;color:var(--t3);padding:4px}
.form-group{margin-bottom:14px}
.form-group label{display:block;font-size:12px;color:var(--t2);margin-bottom:5px;font-weight:500}
.form-group input,.form-group textarea{width:100%;border:0.5px solid var(--bd);border-radius:var(--r-md);padding:10px 12px;font-size:16px;background:var(--bg);color:var(--t1);outline:none;transition:border-color 0.2s}
.form-group input:focus,.form-group textarea:focus{border-color:var(--acc)}
.form-group textarea{resize:vertical;min-height:80px;line-height:1.5;font-size:14px}
.btn{padding:10px 20px;border-radius:var(--r-md);font-size:14px;font-weight:500;cursor:pointer;border:none;transition:all 0.15s}
.btn-primary{background:var(--acc);color:white}
.btn-primary:active{background:var(--acc-dark)}
.btn-outline{background:transparent;border:0.5px solid var(--bd);color:var(--t2)}
.btn-outline:active{background:var(--bg2)}
.btn-sm{padding:7px 14px;font-size:12px}
.btn-danger{background:transparent;border:0.5px solid #E24B4A;color:#E24B4A}
.detail-view{padding-bottom:16px}
.detail-back{display:flex;align-items:center;gap:6px;font-size:14px;color:var(--t2);cursor:pointer;border:none;background:none;padding:10px 0;margin-bottom:8px;font-family:var(--font)}
.detail-title{font-family:'Instrument Serif',serif;font-size:26px;margin-bottom:6px;line-height:1.2}
.detail-tags{display:flex;gap:5px;margin-bottom:12px;flex-wrap:wrap}
.detail-meta{display:flex;gap:14px;margin-bottom:16px;font-size:12px;color:var(--t2)}
.detail-meta span{display:flex;align-items:center;gap:4px}
.section-title{font-size:13px;font-weight:500;text-transform:uppercase;letter-spacing:0.5px;color:var(--t3);margin-bottom:8px;padding-bottom:5px;border-bottom:0.5px solid var(--bd)}
.ingredient-list{list-style:none;margin-bottom:20px}
.ingredient-list li{padding:8px 0;border-bottom:0.5px solid var(--bd);font-size:14px;display:flex;align-items:center;gap:10px;cursor:pointer;-webkit-user-select:none}
.ingredient-list li:last-child{border-bottom:none}
.ing-check{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--bd2);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.ing-check.checked{background:var(--acc);border-color:var(--acc)}
.ing-check.checked::after{content:'';display:block;width:6px;height:6px;background:white;border-radius:50%}
.ing-text.checked{text-decoration:line-through;color:var(--t3)}
.step-list{list-style:none;margin-bottom:20px;counter-reset:steps}
.step-list li{padding:10px 0;font-size:14px;line-height:1.6;display:flex;gap:12px;counter-increment:steps}
.step-list li::before{content:counter(steps);flex-shrink:0;width:24px;height:24px;border-radius:50%;background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;color:var(--t2);margin-top:2px}
.detail-actions{display:flex;gap:8px;margin-top:16px}
.url-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--acc-dark);background:var(--acc-light);padding:4px 10px;border-radius:10px;margin-bottom:10px;text-decoration:none}
.tab-bar{display:flex;border-bottom:0.5px solid var(--bd);margin-bottom:14px}
.tab-bar button{flex:1;padding:10px;background:none;border:none;border-bottom:2px solid transparent;font-size:13px;color:var(--t3);cursor:pointer;font-family:var(--font);transition:all 0.15s}
.tab-bar button.active{color:var(--acc);border-bottom-color:var(--acc);font-weight:500}
.tag-input-row{display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.tag-input-row input{flex:1;min-width:80px}
.mini-tag{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:10px;background:var(--acc-light);color:var(--acc-dark);font-size:12px}
.mini-tag button{background:none;border:none;cursor:pointer;color:var(--acc-dark);font-size:14px;line-height:1;padding:0}
.servings-ctrl{display:inline-flex;align-items:center;gap:8px;margin-bottom:14px}
.servings-ctrl button{width:28px;height:28px;border-radius:50%;border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:var(--t2)}
.fav-toggle{display:flex;gap:8px;margin-bottom:12px}
.fav-btn{padding:6px 16px;border-radius:20px;font-size:12px;cursor:pointer;border:0.5px solid var(--bd);background:var(--bg);transition:all 0.15s;font-family:var(--font);font-weight:500}
.fav-btn.evan-active{background:var(--evan-light);color:var(--evan);border-color:var(--evan)}
.fav-btn.kara-active{background:var(--kara-light);color:var(--kara);border-color:var(--kara)}
.day-row{display:flex;align-items:center;gap:8px;padding:10px 0;border-bottom:0.5px solid var(--bd);font-size:14px}
.day-row:last-child{border-bottom:none}
.day-name{font-weight:500;min-width:34px;color:var(--t2);font-size:12px}
.day-meal{flex:1;min-width:0}
.day-meal input{width:100%;border:none;background:transparent;font-size:14px;color:var(--t1);outline:none;font-family:var(--font);padding:2px 0}
.day-meal input::placeholder{color:var(--t3)}
.day-link-btn{background:none;border:none;cursor:pointer;color:var(--t3);padding:4px;display:flex;align-items:center;opacity:0.5;transition:opacity 0.15s}
.day-link-btn.linked{color:var(--acc);opacity:1}
.grocery-add{display:flex;gap:8px;margin-bottom:14px}
.grocery-add input{flex:1;border:0.5px solid var(--bd);border-radius:var(--r-md);padding:10px 12px;font-size:16px;background:var(--bg);color:var(--t1);outline:none}
.grocery-add input:focus{border-color:var(--acc)}
.grocery-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--bd);font-size:14px}
.grocery-item:last-child{border-bottom:none}
.grocery-text{flex:1}
.grocery-text.checked{text-decoration:line-through;color:var(--t3)}
.copy-banner{position:fixed;top:env(safe-area-inset-top,16px);left:50%;transform:translateX(-50%);background:var(--acc);color:white;padding:10px 20px;border-radius:var(--r-md);font-size:13px;font-weight:500;z-index:300;animation:fadeIO 2s ease forwards;white-space:nowrap}
@keyframes fadeIO{0%{opacity:0;transform:translateX(-50%) translateY(-10px)}15%{opacity:1;transform:translateX(-50%) translateY(0)}85%{opacity:1}100%{opacity:0;transform:translateX(-50%) translateY(-10px)}}
.plan-actions{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.recipe-picker{border:0.5px solid var(--bd);border-radius:var(--r-md);max-height:200px;overflow-y:auto;background:var(--bg);-webkit-overflow-scrolling:touch}
.recipe-pick-item{padding:10px 12px;font-size:13px;cursor:pointer;border-bottom:0.5px solid var(--bd)}
.recipe-pick-item:active{background:var(--bg2)}
.recipe-pick-item:last-child{border-bottom:none}
.pull-btn{display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:var(--r-md);border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;font-size:12px;color:var(--t2);font-family:var(--font);transition:all 0.15s;margin-bottom:12px}
.pull-btn:active{background:var(--bg2)}
.history-week{margin-bottom:16px}
.history-week-header{font-size:12px;font-weight:500;color:var(--t3);text-transform:uppercase;letter-spacing:0.3px;margin-bottom:6px;padding-bottom:4px;border-bottom:0.5px solid var(--bd)}
.history-day{font-size:13px;padding:4px 0;color:var(--t2);display:flex;gap:6px}
.history-day .hd-name{font-weight:500;min-width:30px;color:var(--t3);font-size:12px}
.week-nav{display:flex;align-items:center;gap:4px}
.week-nav button{background:none;border:none;cursor:pointer;padding:4px;color:var(--t2);display:flex;align-items:center}
.week-nav span{font-size:12px;min-width:100px;text-align:center}
.grocery-edit-input{border:none;background:transparent;font-size:14px;color:var(--t1);outline:none;font-family:var(--font);width:100%;padding:0}
.suggestions{margin-bottom:14px}
.suggestions-label{font-size:11px;color:var(--t3);margin-bottom:6px;font-weight:500;text-transform:uppercase;letter-spacing:0.3px}
.sug-chips{display:flex;gap:6px;flex-wrap:wrap}
.sug-chip{padding:6px 12px;border-radius:16px;font-size:12px;border:0.5px solid var(--acc);color:var(--acc-dark);background:var(--acc-light);cursor:pointer;transition:all 0.15s;font-family:var(--font);display:flex;align-items:center;gap:4px}
.sug-chip:active{background:var(--acc);color:white}
.randomizer{text-align:center;padding:20px 16px;margin-bottom:16px;border:0.5px solid var(--bd);border-radius:var(--r-lg);background:var(--bg2)}
.randomizer-result{font-family:'Instrument Serif',serif;font-size:24px;margin:12px 0 4px;min-height:34px;transition:opacity 0.2s}
.randomizer-sub{font-size:12px;color:var(--t3);margin-bottom:2px}
.spin-btn{padding:10px 28px;border-radius:var(--r-md);font-size:14px;font-weight:500;cursor:pointer;border:none;background:var(--acc);color:white;font-family:var(--font);margin-top:10px}
.spin-btn:active{transform:scale(0.97)}
.spinning .randomizer-result{animation:slotSpin 0.1s infinite}
@keyframes slotSpin{0%{opacity:1}50%{opacity:0.3}100%{opacity:1}}
.use-meal-btn{padding:7px 16px;border-radius:var(--r-md);font-size:12px;cursor:pointer;border:0.5px solid var(--acc);color:var(--acc-dark);background:var(--acc-light);font-family:var(--font);margin-top:8px}
.season-hint{font-size:11px;color:var(--acc-dark);background:var(--acc-light);padding:3px 10px;border-radius:10px;margin-top:6px;display:inline-block}
.loading-screen{display:flex;align-items:center;justify-content:center;min-height:60vh;color:var(--t3);font-size:14px}
.sync-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-left:6px}
.sync-dot.online{background:var(--acc)}
.sync-dot.offline{background:#E24B4A}
</style>
</head>
