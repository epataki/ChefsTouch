function parseHTML(html,url){const p=new DOMParser();const doc=p.parseFromString(html,'text/html');let r={title:'',ingredients:[],steps:[],prepTime:0,cookTime:0,servings:4,tags:[],sourceUrl:url,notes:''};const scripts=doc.querySelectorAll('script[type="application/ld+json"]');for(const s of scripts){try{let d=JSON.parse(s.textContent);if(Array.isArray(d))d=d.find(x=>x['@type']==='Recipe')||d[0];if(d['@graph'])d=d['@graph'].find(x=>x['@type']==='Recipe')||d;if(d['@type']==='Recipe'||(Array.isArray(d['@type'])&&d['@type'].includes('Recipe'))){r.title=d.name||'';r.ingredients=(d.recipeIngredient||[]).map(i=>i.trim());if(d.recipeInstructions){if(typeof d.recipeInstructions==='string')r.steps=d.recipeInstructions.split(/\n/).filter(Boolean);else if(Array.isArray(d.recipeInstructions))r.steps=d.recipeInstructions.map(x=>{if(typeof x==='string')return x.trim();if(x.text)return x.text.trim();if(x['@type']==='HowToSection'&&x.itemListElement)return x.itemListElement.map(i=>typeof i==='string'?i:i.text||'').join(' ');return''}).filter(Boolean)}const pd=x=>{if(!x)return 0;return(parseInt((x.match(/(\d+)H/)||[])[1]||0))*60+parseInt((x.match(/(\d+)M/)||[])[1]||0)};r.prepTime=pd(d.prepTime);r.cookTime=pd(d.cookTime);if(d.recipeYield){const y=Array.isArray(d.recipeYield)?d.recipeYield[0]:d.recipeYield;r.servings=parseInt(y)||4}if(d.recipeCategory){const c=Array.isArray(d.recipeCategory)?d.recipeCategory:[d.recipeCategory];r.tags=c.map(x=>x.toLowerCase().trim()).slice(0,3)}return r}}catch(e){}}r.title=(doc.querySelector('h1')||{}).textContent||'Imported Recipe';return r}

function getSuggestions(groceryLog){
  if(!groceryLog||groceryLog.length<3)return[];
  const counts={};
  groceryLog.forEach(entry=>{if(!entry.items)return;entry.items.forEach(item=>{const k=item.toLowerCase().trim();if(!counts[k])counts[k]={total:0,timestamps:[],name:item};counts[k].total++;counts[k].timestamps.push(entry.ts)})});
  const fourWeeks=Date.now()-28*86400000;
  const suggestions=[];
  Object.entries(counts).forEach(([k,v])=>{if(v.total>=3&&v.timestamps.filter(t=>t>fourWeeks).length>=2)suggestions.push({name:v.name,count:v.total})});
  return suggestions.sort((a,b)=>b.count-a.count).slice(0,8);
}

function getMealPool(mealPlan){
  if(!mealPlan)return[];
  const meals={};const skip=['takeout','take out','go out','eat w/','eat w ','pizza night','date night','christmas','thanksgiving','nye','new year','birthday','halloween','valentine','easter','fair','wedding','benefit','party','hockey','races','bowling'];
  Object.entries(mealPlan).forEach(([weekKey,week])=>{
    const weekDate=new Date(weekKey+'T00:00:00');
    Object.values(week).forEach(meal=>{
      if(!meal)return;const m=meal.trim();const lower=m.toLowerCase();
      if(skip.some(x=>lower.includes(x)))return;
      if(lower.length<4)return;
      if(!meals[lower])meals[lower]={name:m,count:0,lastDate:weekDate};
      meals[lower].count++;
      if(weekDate>meals[lower].lastDate)meals[lower].lastDate=weekDate;
    });
  });
  return Object.values(meals).filter(m=>m.count>=1).sort((a,b)=>b.count-a.count);
}

