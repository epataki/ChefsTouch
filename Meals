  const a=year%19,b=Math.floor(year/100),c=year%100,dd=Math.floor(b/4),ee=b%4;
  const f=Math.floor((b+8)/25),g=Math.floor((b-f+1)/3),h=(19*a+b-dd-g+15)%30;
